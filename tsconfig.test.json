{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "moduleResolution": "node",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": false
  },
  "include": ["src"]
}
